{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build locolm",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-o",
        "${workspaceFolder}/bin/locolm.exe",
        "./cmd/locolm/"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$go"
      ]
    }
  ]
}
